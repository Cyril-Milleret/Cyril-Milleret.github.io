### 1.7 fit the SARE model ####
monitor <- c("p0","sigma","mhH", "N","logit.eta","log.phi",
"gamma","tau","betaH")
monitor2 <- c("h","w")
modelCode <- modelCodeSARE
setwd(file.path(WD, modelName,"NimbleInFiles"))
TrueValues <- list(W= cmodel$W,
s= cmodel$s,
z= cmodel$z,
N= cmodel$N,
h= cmodel$h,
w= cmodel$w)
for(ch in 1:4){
save(monitor,monitor2,modelCode,nimConstants,nimData,nimInits,TrueValues,
file=paste("NimbleInFileSARESet",paramSpace$set_ID[set],"Rep",paramSpace$rep_ID[set],"Chain",ch,".RData",sep=""))
}
### 1.8 fit the CAR model ####
modelCodeCAR <- nimbleCode({
##--------------------------------------------------------------------------------------------
##-----------------------------##
##------ SPATIAL PROCESS ------##
##-----------------------------##
tau ~ dgamma(0.001, 0.001)
logHabIntensity[1:numHabWindows] <- mu[1:numHabWindows]
sumHabInt <- log(sum(mu[1:numHabWindows]))
## FIRST YEAR
for(i in 1:M){
s[i, 1:2,1] ~ dbernppAC(
lowerCoords = lowerHabCoords[1:numHabWindows, 1:2],
upperCoords = upperHabCoords[1:numHabWindows, 1:2],
logIntensities = logHabIntensity[1:numHabWindows],
logSumIntensity = sumHabInt,
habitatGrid = habitatGrid[1:y.max,1:x.max],
numGridRows =  y.max,
numGridCols = x.max
)
}#i
## T>1
for(t in 2:n.years){
for(i in 1:M){
s[i, 1:2, t] ~ dbernppACmovement_normal(lowerCoords = lowerHabCoords[1:numHabWindows, 1:2]
, upperCoords = upperHabCoords[1:numHabWindows, 1:2]
, s = s[i, 1:2, t - 1]
, sd = tau
, baseIntensities = mu[1:numHabWindows]
, habitatGrid =  habitatGrid[1:y.max,1:x.max]
, numGridRows = y.max
, numGridCols = x.max
, numWindows= numHabWindows
)
}#i
}#t
##--------------------------------------------------------------------------------------------
##-------------------------------##
##----- DEMOGRAPHIC PROCESS -----##
##-------------------------------##
## INTERCEPT MORTALITY HAZARD RATES
mhH ~ dunif(-10, 10)
## CAUSE SPECIFIC SLOPE MORTALITY
betaH ~ dunif(-10,10)
## FIRST YEAR INCLUSION PARAMETER
gamma1 ~ dunif(0,1)
omeg1[1:2] <- c(1-gamma1, gamma1)
## TIME SPECIFIC INCLUSION PARAMETER
for(t in 1:n.years1){
gamma[t] ~ dunif(0,1)
}#t
#dgamma(0.001, 0.001)
# tauCar ~ dgamma(3, 0.5)
tauCar ~ dgamma(3, 0.5)
icarVals[1:numHabWindows] ~ dcar_normal(adj[1:L], weights[1:L], numadj[1:numHabWindows],
tau = tauCar, zero_mean = 0)
## ICAR process in a non-centred parameterisation
# mu0[1:numHabWindows] ~ dcar_normal(adj[1:L], weights[1:L], numadj[1:numHabWindows], tau = 1, zero_mean = 0)
# sqrtau <- sqrt(tauCar)
# icarVals[1:numHabWindows] <- mu0[1:numHabWindows]/sqrtau
## Add to the posterior distribution a Jacobian correction (tau^{-1/2}) due to the transformation above
## zero is a scalar data point with whatever value provided
## Omitting this does not make a big difference...
# zero ~ dfixCARprior(tau = tauCar)
## SPATIAL SURVIVAL
## SURVIVAL (CAUSE-SPECIFIC MORTALITY SPATIALLY EXPLICIT)
#legal mortality are function of an intercept and a linear effect of a covariate
mhH1[1:numHabWindows] <- exp(mhH + betaH * habCov[1:numHabWindows])
#mortality events not detected are function of a CAR surface
mhW1[1:numHabWindows] <- exp(icarVals[1:numHabWindows])#exp(mhW + betaW * habCov[1:numHabWindows])
## DERIVE MORTALITY AND SURVIVAL PROBABILITIES
phi[1:numHabWindows] <- exp(-(mhH1[1:numHabWindows] + mhW1[1:numHabWindows]))
h[1:numHabWindows] <-  (1 - phi[1:numHabWindows]) * (mhH1[1:numHabWindows]/(mhH1[1:numHabWindows] +
mhW1[1:numHabWindows]))
w[1:numHabWindows] <-  (1 - phi[1:numHabWindows]) * (mhW1[1:numHabWindows]/(mhH1[1:numHabWindows] +
mhW1[1:numHabWindows]))
## STATE TRANSITION
for(i in 1:M){
z[i,1] ~ dcat(omeg1[1:2])
for(t in 1:n.years1){
z[i,t+1] ~ dcatState1Alive2Dead( z = z[i,t]
, prob1To2 = gamma[t]
, prob2To3Hab = h[1:numHabWindows]
, prob2To4Hab = w[1:numHabWindows]
, s = s[i,1:2,t]
, habitatGrid = habitatGrid[1:y.max,1:x.max])
}#i
}#t
##---------------------------------------------------------------------------------------------
##-----------------------------##
##----- DETECTION PROCESS -----##
##-----------------------------##
sigma ~ dunif(0,15)
p0 ~ dunif(0,1)
for(t in 1:n.years){
for (i in 1:M){
## ALIVE DETECTIONS
y[i, 1:lengthYCombined,t] ~ dbinomLocal_normal(size = trials[1:n.traps],
p0 = p0,
s = s[i,1:2,t],
sigma = sigma,
trapCoords = trapCoords[1:n.traps,1:2],
localTrapsIndices = trapIndex[1:n.cells,1:maxNBDets],
localTrapsNum = nTraps[1:n.cells],
resizeFactor = resizeFactor,
habitatGrid = habitatIDDet[1:y.maxDet,1:x.maxDet],
indicator = isAlive[i,t],
lengthYCombined = lengthYCombined)
## DEAD RECOVERY
y.dead[i, 1:3,t] ~ dbernppLocalDetection_normal(
lowerCoords= lowerHabCoords[1:numHabWindows,1:2]
, upperCoords= upperHabCoords[1:numHabWindows,1:2]
, s = s[i,1:2,t]
, sd = sigma
, baseIntensities = detReco[1:numHabWindows]
, habitatGridLocal=habitatGridLocal[1:y.max,1:x.max]
, resizeFactor=resizeFactor
, localObsWindowIndices = localObsWindowIndices[1:numHabWindows,1:maxNBDetsReco]
, numLocalObsWindows = numLocalObsWindows[1:numHabWindows]
, numWindows = numHabWindows
, indicator = z[i,t]==3
)
}#i
}#t
##---------------------------------------------------------------------------------------------
##----------------------------------------##
##---------- DERIVED PARAMETERS ----------##
##----------------------------------------##
for(i in 1:M){
isAlive[i,1] <- (z[i,1] == 2)
for(t in 1:n.years1){
isAlive[i,t+1] <- (z[i,t+1] == 2)
}
}
for(t in 1:n.years){
N[t] <- sum(isAlive[1:M,t])
}#t
})
### 1.9 Spatial adjacency structure for the CAR model ####
## Spatial adjacency structure for using the CAR model (for simulations below and for use in the model code)
## Code retrive from the work from Wei on density
## only use the 4 (maximum) neigbouring cells
adj <- NULL   ## A vector specifying the neighboring location indices of each grid cell
numadj <- NULL   ## A vector giving the number of neighboring locations of each grid cell
nHabRows <- dim(habitatMask)[1] ## Number of rows of the habitat grid
nHabCols <- dim(habitatMask)[2] ## Number of columns of the habitat grid
k <- 0
for(i in 1:nHabRows){
for(j in 1:nHabCols){
if(lowerAndUpperCoords$habitatGrid[i, j] > 0){ ## A non-zero ID means the cell is 'true' habitat
k <- k + 1
len_adj <- length(adj)
if(i > 1 && lowerAndUpperCoords$habitatGrid[i-1, j] > 0) adj <- c(adj, lowerAndUpperCoords$habitatGrid[i-1, j])
if(j > 1 && lowerAndUpperCoords$habitatGrid[i, j-1] > 0) adj <- c(adj, lowerAndUpperCoords$habitatGrid[i, j-1])
if(j < nHabCols && lowerAndUpperCoords$habitatGrid[i, j+1] > 0) adj <- c(adj, lowerAndUpperCoords$habitatGrid[i, j+1])
if(i < nHabRows && lowerAndUpperCoords$habitatGrid[i+1, j] > 0) adj <- c(adj, lowerAndUpperCoords$habitatGrid[i+1, j])
numadj[k] <- length(adj) - len_adj
}
}
}
L <- length(adj)
weights <- rep(1, L)
nimData$weights <- weights
nimConstants$L <- L
nimConstants$numadj <- numadj
nimConstants$adj <- adj
nimData$zero <- 0
#set inits values
nimInits$tauCar <- 1#"runif(1,0,0.01)
nimInits$log.phi <- NULL
nimInits$logit.eta <- NULL
nimInits$icarVals <- nimInits$W/sqrt(nimInits$tauCar)
nimInits$mu0 <- nimInits$W
###
monitor <- c("p0","sigma","mhH", "N","tauCar",
"gamma","tau","betaH")
monitor2 <- c("h","w")
dfixCARprior <- nimbleFunction(
run = function(x = double(0),
tau = double(0),
log = logical(0, default = 0)){
returnType(double())
logProb <- -log(tau)/2
if(log) return(logProb)
else return(exp(logProb))
}
)
registerDistributions("dfixCARprior")
modelCode <- modelCodeCAR
setwd(file.path(WD, modelName,"NimbleInFiles"))
for(ch in 1:4){
save(monitor,monitor2,modelCode,nimConstants,nimData,nimInits,TrueValues,
file=paste("NimbleInFileCARSet",paramSpace$set_ID[set],"Rep",paramSpace$rep_ID[set],"Chain",ch,".RData",sep=""))
}
