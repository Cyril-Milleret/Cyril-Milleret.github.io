output = FALSE)
modelSapt_mkemig <- mark(bear.process,
bear.ddl,
model.parameters=list(S = S.age,
GammaPrime = GammaPrimeMK,
GammaDoublePrime = GammaDoublePrimeMK,
p = p.time),
threads = 2,
output = FALSE)
