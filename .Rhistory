plot(lowerAndUpperCoords$upperHabCoords[,2]~lowerAndUpperCoords$upperHabCoords[,1], ylim=c(0,7),xlim=c(0,7))
points(lowerAndUpperCoords$lowerHabCoords[,2]~lowerAndUpperCoords$lowerHabCoords[,1])
points(centerGrid[,2]~centerGrid[,1],col="red")
centerGridsf <-  st_as_sf(data.frame(centerGrid), coords = c("x", "y"))
dist <- st_distance(centerGridsf,centerGridsf)
distConsidered <- 5
#create nimble objects
weightList <- apply(dist,1,function(x) x[x<distConsidered & x>0])#0 remove also the focal cell
adjList <- apply(dist,1,function(x) which(x<distConsidered & x>0))#0 remove also the focal cell
numadjList <- lapply(adjList,length)
#CHECK THIS
plot(centerGrid[,2]~centerGrid[,1])
id <- 1
points(centerGrid[id,2]~centerGrid[id,1],col="red",pch=16)
points(centerGrid[adjList[[id]],2]~centerGrid[adjList[[id]],1],col="blue",pch=16)
nimData$weights <- min(unlist(weightList))/unlist(weightList)#rescale to give more importance to value very close to the cell
nimConstants$L <- length(unlist(adjList))
nimConstants$numadj <- unlist(numadjList)
nimConstants$adj <- unlist(adjList)
